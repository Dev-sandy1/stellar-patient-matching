# Terminal 3 API Key (from https://www.terminal3.io/claim-page)
T3N_API_KEY=

# Agent Key (Ethereum private key for the matching agent - generate your own)
AGENT_KEY=

# EHR System API Key (mock or test key for hospital EHR integration)
EHR_API_KEY=mock-ehr-key

# EHR Base URL (your backend API URL)
EHR_BASE_URL=http://localhost:3008

# MongoDB Connection String (leave empty to use in-memory storage)
# Example: mongodb://localhost:27017 or mongodb+srv://user:pass@cluster.mongodb.net/stellar-patient-matching
MONGODB_URI=

# Wallet Encryption Key (generate with: openssl rand -hex 32)
# This encrypts patient private keys in the database
WALLET_ENCRYPTION_KEY=

# Clinical Trials System API Key (mock or test key for trials API)
TRIALS_API_KEY=mock-trials-key

# LLM Configuration
LLM_PROVIDER=groq
GROQ_API_KEY=
GEMINI_API_KEY=

# ─── Populated after running setup.ts ─────────────────────────────────────────
PHARMA_TENANT_DID=
HOSPITAL_TENANT_DID=

# Server port (defaults to 3008 to match Cloud Run setup)
PORT=3008

# Optional: override script versions if different from 0.1.0
PHARMA_SCRIPT_VERSION=
HOSPITAL_SCRIPT_VERSION=

