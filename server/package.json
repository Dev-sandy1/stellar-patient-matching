{
  "name": "stellar-patient-matching-server",
  "version": "0.1.0",
  "description": "TEE-governed clinical trial patient matching on Terminal 3 Network",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "setup": "tsx src/scripts/setup.ts",
    "authorize": "tsx src/scripts/authorize.ts",
    "invoke": "tsx src/scripts/invoke.ts",
    "seed": "tsx src/scripts/seed.ts",
    "build:pharma": "cd ../contracts/pharma-trial && cargo build --target wasm32-wasip2 --release",
    "build:hospital": "cd ../contracts/hospital-screening && cargo build --target wasm32-wasip2 --release",
    "build:all": "pnpm build:pharma && pnpm build:hospital",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "terminal3",
    "tee",
    "clinical-trials",
    "patient-matching",
    "confidential-computing"
  ],
  "author": "",
  "license": "ISC",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.7.0",
      "onFail": "download"
    }
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/env": "^7.0.0",
    "@fastify/multipart": "^10.0.0",
    "@google/generative-ai": "^0.24.1",
    "@terminal3/t3n-sdk": "^3.6.0",
    "@types/node": "^25.9.3",
    "dotenv": "^17.4.2",
    "ethers": "6.13.0",
    "fastify": "^5.8.5",
    "groq-sdk": "^1.2.1",
    "mongodb": "^7.3.0",
    "pdf-parse": "^2.4.5",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "pino-pretty": "^13.1.3",
    "vitest": "^4.1.9"
  }
}
